# Copy this file to .env and fill in your values

# Server
PORT=3000
ARCJET_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=abona_shop
DB_SSL=false

# JWT secrets — use long random strings
JWT_SECRET=change_this_to_a_long_random_secret
JWT_ADMIN_SECRET=change_this_to_a_different_long_random_secret

# Arcjet — get your key at https://arcjet.com
ARCJET_KEY=ajkey_...

# Frontend origin for CORS
CLIENT_ORIGIN=http://127.0.0.1:5500

# Stripe — get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email (Brevo HTTP API) — get key at https://app.brevo.com
BREVO_API_KEY=xkeysib_...
BREVO_SENDER_EMAIL=you@gmail.com
ADMIN_EMAIL=admin@yourdomain.com
