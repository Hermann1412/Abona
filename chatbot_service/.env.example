# Copy this file to .env and fill in real values.

# Bot service
BOT_PORT=8000

# Database — LEAVE BLANK to use the built-in SQLite test database.
# Fill these in to connect to your real MySQL (local XAMPP or Aiven).
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Optional — path to SQLite file (defaults to bot/abona_test.db)
SQLITE_PATH=
